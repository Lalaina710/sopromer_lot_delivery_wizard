<odoo>

    <!--
        Ajoute un bouton "Assistant lots" + une colonne badge de dispo
        stock sur chaque ligne du tableau des mouvements (onglet Operations)
        du BL. Visible uniquement :
          - picking sortant (outgoing)
          - mouvement non done / non cancel
    -->
    <record id="sopromer_stock_picking_form_lot_wizard" model="ir.ui.view">
        <field name="name">stock.picking.form.sopromer.lot.wizard</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids_without_package']/list/field[@name='product_uom_qty']"
                   position="before">
                <field name="stock_warning_label" column_invisible="1"/>
                <field name="stock_warning_level"
                       widget="badge"
                       string="Dispo"
                       decoration-success="stock_warning_level == 'ok'"
                       decoration-warning="stock_warning_level == 'warning'"
                       decoration-danger="stock_warning_level == 'danger'"
                       decoration-muted="stock_warning_level == 'none'"
                       invisible="parent.picking_type_code != 'outgoing' or state in ('done', 'cancel')"
                       optional="show"/>
                <button name="action_open_lot_wizard"
                        type="object"
                        string="Assistant lots"
                        icon="fa-magic"
                        invisible="parent.picking_type_code != 'outgoing' or product_id == False or state in ('done', 'cancel')"
                        help="Ouvrir l'assistant de selection des lots (FIFO, checkbox, qty modifiable)."/>
            </xpath>
        </field>
    </record>

</odoo>
